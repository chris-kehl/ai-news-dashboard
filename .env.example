# Copy to .env and fill in your values

# OpenRouter (free LLM summarization)
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Email Notifications (SMTP)
# Gmail: use an App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# Alternatively use Outlook:
# SMTP_SERVER=smtp.office365.com
# EMAIL_USERNAME=your@outlook.com
# EMAIL_PASSWORD=your_app_password_here

# Telegram Notifications
# 1. Message @BotFather on Telegram, create a bot, copy the token
# 2. Message @userinfobot to get your chat ID
# 3. Or add the bot to a group and use the group chat ID (starts with -)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Notifications
# 1. In your Discord server: Server Settings > Integrations > Webhooks
# 2. Create a webhook and copy the full URL
DISCORD_WEBHOOK_URL=

# Healthcheck Ping URL
# Services: Uptime Kuma (push monitor), Healthchecks.io, Cronitor
# This URL gets pinged every successful scrape. If it stops pinging, you get alerted.
# Uptime Kuma: Add monitor -> Push -> copy URL
# Healthchecks.io: Create check -> copy ping URL
HEALTHCHECK_URL=
