# Copy to .env and fill in your values

# —— Weather Zip (drives local Reddit r/{city} + r/{state}) ——
WEATHER_ZIP=40272

# —— NewsAPI for local news (free tier: 100 req/day) ——
# Get key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# —— OpenRouter (optional, free LLM summarization) ——
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# —— Email Notifications (optional) ——
# Gmail: use an App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=you@email.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=you@email.com
EMAIL_TO=you@email.com

# —— Telegram Notifications (optional) ——
# 1. Message @BotFather on Telegram, create a bot, copy the token
# 2. Message @userinfobot to get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# —— Discord Notifications (optional) ——
# 1. In your Discord server: Server Settings > Integrations > Webhooks
# 2. Create a webhook and copy the full URL
DISCORD_WEBHOOK_URL=

# —— Healthcheck Ping URL (optional) ——
# Services: Uptime Kuma (push monitor), Healthchecks.io, Cronitor
# This URL gets pinged every successful scrape. If it stops pinging, you get alerted.
# Uptime Kuma: Add monitor -> Push -> copy URL
# Healthchecks.io: Create check -> copy ping URL
HEALTHCHECK_URL=
